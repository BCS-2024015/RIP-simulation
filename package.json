{
  "name": "ripv2-network-simulator",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "electron:dev": "wait-on tcp:5173 && electron .",
    "build:win": "vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.aethernet.simulator",
    "productName": "AetherNet Simulator",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable"
    },
    "asar": false,
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.10",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.5"
  }
}